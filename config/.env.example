# Copia este archivo como .env y llena los valores reales.
# NUNCA compartas este archivo ni lo subas a git.

# --- Instagram (Meta Graph API) ---
# Se obtiene en developers.facebook.com, tras crear la app y el producto "Instagram Graph API"
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# --- TikTok (TikTok for Developers) ---
# Client key/secret: los ves en developers.tiktok.com -> tu app -> Basic Information
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Estos dos los llena automaticamente scripts/tiktok_oauth_helper.py
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
